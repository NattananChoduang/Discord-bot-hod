{
  "name": "discord-bot",
  "version": "1.0.0",
  "description": "Discord Bot with modular features",
  "main": "index.js",
  "bin": "index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "register": "node scripts/command.js",
    "setup": "node scripts/setup-db.js",
    "build": "pkg . --targets node18-win-x64 --output bot.exe"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "discord.js": "^14.15.3",
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "src/features/**/*",
      "src/core/**/*",
      "database.json"
    ]
  }
}
